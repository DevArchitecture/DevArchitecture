@page "/not-found"
@layout MainLayout
@inject AuthState AuthState

<h3>@Translate("notFound.title", "Not Found")</h3>
<p>@Translate("notFound.message", "Sorry, the content you are looking for does not exist.")</p>

@code {
    private string Translate(string key, string fallback) => AuthState.T(key, fallback);
}